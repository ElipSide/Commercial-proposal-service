@dp.message(F.text.lower() == "обновить бота")
async def with_puree(message: types.Message):
    if message.from_user.id not in [769657026, 5232657726]:
        await message.answer(f'Нет доступа к команде')
        return
    Users = await workUser.is_users()
    await message.answer(f'Начали рассылку по {len(Users)} пользователям')
    for user in Users:
        try:
            id = user[0]
            messag = f"Привет, Мы обновили функционал,\nчтобы не было проблем, нажми /start еще раз"
            await bot.send_message(id,messag, reply_markup=types.ReplyKeyboardRemove())
        except:
            await bot.send_message(5232657726,f'Чата с пользователеим {id} не существует')
        time.sleep(1)


