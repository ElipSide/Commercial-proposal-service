@dp.message()
async def test(message: Message) -> None:
    botCl = replyButton(str(message.from_user.id), message.from_user.username)

    if 'Получить_Кп_№' in message.text:

        keyCP = message.text.split('Получить_Кп_№')[1]
        is_exists = await workUser.is_user_exists(str(message.from_user.id))
        id_manag = await workUser.is_id_manag(str(keyCP))
        if is_exists != False:
            url = f'https://csort-news.ru/offer/PDF?keyCP={keyCP}&tg_id={str(id_manag)}'
            keyboard = {"inline_keyboard": [
                        # [{"text": "Посмотреть КП", "web_app": {'url':escaped_url}}],
                            [{"text": "Открыть КП",  "web_app": {'url':url}}]
                            ]}
            await message.answer(f'Посмотреть КП №{keyCP}', reply_markup= keyboard)
            return






from magic_filter import F

@dp.callback_query(NumbersCallbackFactory.filter(F.action == "change"))
async def callbacks_num_change_fab(
        callback: types.CallbackQuery, 
        callback_data: NumbersCallbackFactory):
    botCl = replyButton(str(callback.from_user.id), callback.from_user.username)

    stat = await workUser.company_stat(callback_data.value)
    stat_week = stat['week']
    stat_month = stat['month']
    result_week = botCl.process_statistics(stat_week)
    result_month = botCl.process_statistics(stat_month)
    date_week = botCl.format_date_range(7)
    date_month = botCl.format_date_range(31)
    text = (
        f"Статистика компании {html.bold(callback_data.value)}\n"
        f"Коммерчиские предложения\n"
        f"{html.bold(f'За неделю({date_week})')}:\n"
        f" Договоров: {result_week['КП']['Договор']['count']} общей суммой {botCl.format_numbers(result_week['КП']['Договор']['sum'])}\n"
        # f" С компаниями: {', '.join(result_week['Договор']['company'])}\n"
        f" Счетов: {result_week['КП']['Счет']['count']} общей суммой {botCl.format_numbers(result_week['КП']['Счет']['sum'])}\n"
        # f" С компаниями: {', '.join(result_week['Счет']['company'])}\n\n"
        f"{html.bold(f'За месяц({date_month})')}:\n"
        f" Договоров: {result_month['КП']['Договор']['count']} общей суммой {botCl.format_numbers(result_month['КП']['Договор']['sum'])}\n"
        # f" С компаниями: {', '.join(result_month['Договор']['company'])}\n"
        f" Счетов: {result_month['КП']['Счет']['count']} общей суммой {botCl.format_numbers(result_month['КП']['Счет']['sum'])}\n\n"
        # f" С компаниями: {', '.join(result_month['Счет']['company'])}\n"
        f"Сервисные услуги\n"
        f"{html.bold(f'За неделю({date_week})')}:\n"
        f" Договоров: {result_week['Сервис']['Договор']['count']} общей суммой {botCl.format_numbers(result_week['Сервис']['Договор']['sum'])}\n"
        # f" С компаниями: {', '.join(result_week['Договор']['company'])}\n"
        f" Счетов: {result_week['Сервис']['Счет']['count']} общей суммой {botCl.format_numbers(result_week['Сервис']['Счет']['sum'])}\n"
        # f" С компаниями: {', '.join(result_week['Счет']['company'])}\n\n"
        f"{html.bold(f'За месяц({date_month})')}:\n"
        f" Договоров: {result_month['Сервис']['Договор']['count']} общей суммой {botCl.format_numbers(result_month['Сервис']['Договор']['sum'])}\n"
        # f" С компаниями: {', '.join(result_month['Договор']['company'])}\n"
        f" Счетов: {result_month['Сервис']['Счет']['count']} общей суммой {botCl.format_numbers(result_month['Сервис']['Счет']['sum'])}\n\n"
        f" Пользователи: {result_month['id']}\n\n"
    )

    await bot.send_message(callback.from_user.id, text) 


